{
  "version": 2,
  "buildCommand": "ng build -c production && ng run rapid-pharmaceuticals:server",
  "outputDirectory": "dist/rapid-pharmaceuticals/browser",
  "functions": {
    "dist/rapid-pharmaceuticals/server/main.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/rapid-pharmaceuticals/server/main.js"
    }
  ]
}